{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photographerthemovie.com/schemas/site-content.schema.json",
  "title": "Photographer campaign content",
  "type": "object",
  "additionalProperties": false,
  "required": ["build", "film", "contact", "navigation", "booking", "notifications", "social", "videos", "shorts", "cast", "crew"],
  "properties": {
    "$schema": { "type": "string" },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": { "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" } }
    },
    "film": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "releaseDate", "contentRating", "releaseFormat", "heroVideoId"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "releaseDate": { "type": "string", "format": "date" },
        "contentRating": { "type": "string", "minLength": 1 },
        "releaseFormat": { "type": "string", "minLength": 1 },
        "heroVideoId": { "type": "string", "minLength": 1 }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email"],
      "properties": { "email": { "type": "string", "format": "email" } }
    },
    "navigation": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/internalLink" } },
    "booking": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cities", "partners"],
      "properties": {
        "cities": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "partners": { "type": "array", "items": { "$ref": "#/$defs/externalLink" } }
      }
    },
    "notifications": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "endpoint", "privacyUrl", "consentText"],
      "properties": {
        "enabled": { "type": "boolean" },
        "endpoint": { "type": "string" },
        "privacyUrl": { "type": "string" },
        "consentText": { "type": "string" }
      },
      "allOf": [{
        "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
        "then": {
          "properties": {
            "endpoint": { "type": "string", "format": "uri", "pattern": "^https://" },
            "privacyUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
            "consentText": { "type": "string", "minLength": 1 }
          }
        }
      }]
    },
    "social": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "$ref": "#/$defs/externalLink" } }
    },
    "videos": { "type": "array", "items": { "$ref": "#/$defs/video" } },
    "shorts": { "type": "array", "items": { "$ref": "#/$defs/short" } },
    "cast": { "type": "array", "items": { "$ref": "#/$defs/person" } },
    "crew": { "type": "array", "items": { "$ref": "#/$defs/credit" } }
  },
  "$defs": {
    "externalLink": {
      "type": "object", "additionalProperties": false, "required": ["label", "href"],
      "properties": { "label": { "type": "string", "minLength": 1 }, "href": { "type": "string", "format": "uri", "pattern": "^https://" } }
    },
    "internalLink": {
      "type": "object", "additionalProperties": false, "required": ["label", "href"],
      "properties": { "label": { "type": "string", "minLength": 1 }, "href": { "type": "string", "pattern": "^#[A-Za-z][A-Za-z0-9_-]*$" } }
    },
    "video": {
      "type": "object", "additionalProperties": false, "required": ["title", "kind", "duration", "videoId"],
      "properties": { "title": { "type": "string", "minLength": 1 }, "kind": { "type": "string", "minLength": 1 }, "duration": { "type": "string", "pattern": "^\\d+:\\d{2}$" }, "videoId": { "type": ["string", "null"] } }
    },
    "short": {
      "type": "object", "additionalProperties": false, "required": ["title", "meta", "views", "videoId"],
      "properties": { "title": { "type": "string", "minLength": 1 }, "meta": { "type": "string", "minLength": 1 }, "views": { "type": "string", "minLength": 1 }, "videoId": { "type": ["string", "null"] } }
    },
    "person": {
      "type": "object", "additionalProperties": false, "required": ["name", "role", "tag", "socialProfile"],
      "properties": { "name": { "type": "string", "minLength": 1 }, "role": { "type": "string", "minLength": 1 }, "tag": { "type": "string", "minLength": 1 }, "socialProfile": { "type": ["string", "null"] } }
    },
    "credit": {
      "type": "object", "additionalProperties": false, "required": ["role", "name"],
      "properties": { "role": { "type": "string", "minLength": 1 }, "name": { "type": "string", "minLength": 1 } }
    }
  }
}
